# Keycloak
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=innovatech
KEYCLOAK_CLIENT_ID=innovatech-frontend

# API Gateway (único punto expuesto al frontend)
VITE_API_URL=http://localhost:8080
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=innovatech
VITE_KEYCLOAK_CLIENT_ID=innovatech-frontend

# Backend (desarrollo local)
EUREKA_URL=http://localhost:8761/eureka/
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/innovatech

# PostgreSQL (Docker Compose: servicio postgres; local: localhost:5432)
# Volumen Docker: innovatech_postgres_data (docker compose down sin -v no lo borra)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=innovatech
POSTGRES_PASSWORD=innovatech_dev

# Usuarios Keycloak de prueba
# demo / demo123
# admin / admin123
